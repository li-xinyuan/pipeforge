# ConfigForge Environment Variables
# Copy this file to .env and fill in the values

# === Environment ===
# Application environment: development (default) or production
# In production mode, CONFIGFORGE_JWT_SECRET, CONFIGFORGE_ENCRYPTION_KEY,
# and CORS_ORIGINS are strictly required.
CONFIGFORGE_ENV=development

# === Authentication ===
# API Key for authentication (empty = development mode, all requests allowed)
CONFIGFORGE_API_KEY=

# === Data Directories ===
# Root data directory for configs, connections, schedules, etc.
# CONFIGFORGE_DATA_DIR=./data

# Upload directory for input files
# CONFIGFORGE_UPLOAD_DIR=tmp/uploads

# Log directory for pipeline execution logs
# CONFIGFORGE_LOG_DIR=tmp/logs

# Output directory for pipeline results
# CONFIGFORGE_OUTPUT_DIR=./data/outputs

# === Pipeline ===
# Pipeline execution timeout in seconds (default: 300)
# CONFIGFORGE_PIPELINE_TIMEOUT=300

# === Security ===
# JWT secret for authentication (required in production, length ≥ 32)
CONFIGFORGE_JWT_SECRET=
# Fernet encryption key for storing credentials (empty = auto-generate)
# ⚠️  WARNING: If CONFIGFORGE_ENCRYPTION_KEY is not set, an auto-generated key file
# (.fernet_key) is created in the data directory. In Docker or other ephemeral
# environments, this file is LOST on container restart, making ALL encrypted
# credentials (database passwords, API keys, SMTP passwords) UNRECOVERABLE.
# You MUST set this variable in production to prevent data loss.
CONFIGFORGE_ENCRYPTION_KEY=

# === CORS ===
# Comma-separated list of allowed origins.
# ⚠️  MUST be set for production. If empty, defaults to localhost dev servers only.
# CORS_ORIGINS=https://your-production-domain.com

# === AI ===
# AI provider and model are configured via the Settings page in the UI
# No environment variables needed for AI configuration

# === Email Notifications (SMTP) ===
# SMTP server for sending email notifications
# CONFIGFORGE_SMTP_HOST=smtp.example.com
# CONFIGFORGE_SMTP_PORT=587
# CONFIGFORGE_SMTP_USER=
# CONFIGFORGE_SMTP_PASSWORD=
# CONFIGFORGE_SMTP_TLS=true

# === Storage Backend (T-5E-03) ===
# Storage backend type: json (default), sqlite, or postgresql
# - json:       Single-machine, file-based storage. Zero ops. Good for dev / small teams.
# - sqlite:     Single-file database. Better query performance. Good for single-machine production.
# - postgresql: Network database. Multi-instance, high concurrency. Good for production / cluster.
# See docs/DEPLOYMENT.md "存储后端选择" for detailed guidance.
# CONFIGFORGE_STORAGE_BACKEND=json

# SQLite database file path (only used when CONFIGFORGE_STORAGE_BACKEND=sqlite)
# Default: <CONFIGFORGE_DATA_DIR>/configforge.db
# CONFIGFORGE_SQLITE_PATH=./data/configforge.db

# PostgreSQL connection URL (required when CONFIGFORGE_STORAGE_BACKEND=postgresql)
# Format: postgresql://user:password@host:5432/dbname
# CONFIGFORGE_DATABASE_URL=postgresql://configforge:password@localhost:5432/configforge
